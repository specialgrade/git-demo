@model IEnumerable<git_demo.Models.Post>

@{
    ViewData["Title"] = "All Posts";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500&display=swap');

    :root {
        --ink: #1a1a2e;
        --muted: #6b6b80;
        --accent: #c0392b;
        --rule: #e2e2ea;
        --card-bg: #ffffff;
        --page-bg: #f5f5f0;
    }

    .posts-page {
        font-family: 'DM Sans', sans-serif;
        background-color: var(--page-bg);
        min-height: 100vh;
        padding: 3rem 1.5rem 5rem;
    }

    /* ── Page header ── */
    .posts-header {
        max-width: 860px;
        margin: 0 auto 3rem;
        border-bottom: 2px solid var(--ink);
        padding-bottom: 1.25rem;
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
    }

    .posts-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 700;
        color: var(--ink);
        letter-spacing: -0.5px;
        margin: 0;
        line-height: 1;
    }

    .posts-header .post-count {
        font-size: 0.8rem;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted);
        white-space: nowrap;
    }

    /* ── Card grid ── */
    .post-grid {
        max-width: 860px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .post-card {
        background: var(--card-bg);
        border: 1px solid var(--rule);
        border-bottom: none;
        padding: 1.75rem 2rem;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 0.5rem 1.5rem;
        align-items: start;
        transition: background 0.15s ease;
        position: relative;
    }

    .post-card:first-child { border-radius: 6px 6px 0 0; }
    .post-card:last-child  { border-bottom: 1px solid var(--rule); border-radius: 0 0 6px 6px; }
    .post-card:only-child  { border-radius: 6px; border-bottom: 1px solid var(--rule); }

    .post-card::before {
        content: '';
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 3px;
        background: var(--accent);
        opacity: 0;
        transition: opacity 0.2s ease;
        border-radius: 6px 0 0 6px;
    }

    .post-card:hover { background: #fafafa; }
    .post-card:hover::before { opacity: 1; }

    .post-card-body { min-width: 0; }

    .post-card-meta {
        font-size: 0.72rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 0.4rem;
    }

    .post-card-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.2rem;
        font-weight: 700;
        line-height: 1.3;
        margin: 0 0 0.5rem;
    }

    .post-card-title a {
        color: var(--ink);
        text-decoration: none;
        background-image: linear-gradient(var(--accent), var(--accent));
        background-repeat: no-repeat;
        background-position: 0 100%;
        background-size: 0% 2px;
        transition: background-size 0.25s ease, color 0.15s ease;
    }

    .post-card-title a:hover {
        color: var(--accent);
        background-size: 100% 2px;
    }

    .post-card-excerpt {
        font-size: 0.9rem;
        color: var(--muted);
        line-height: 1.6;
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .post-card-action {
        display: flex;
        align-items: center;
        align-self: center;
    }

    .btn-details {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.78rem;
        font-weight: 500;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--ink);
        text-decoration: none;
        border: 1.5px solid var(--ink);
        padding: 0.45rem 0.9rem;
        border-radius: 3px;
        transition: background 0.15s ease, color 0.15s ease;
        white-space: nowrap;
    }

    .btn-details:hover {
        background: var(--ink);
        color: #fff;
    }

    .btn-details svg { flex-shrink: 0; }

    /* ── Empty state ── */
    .empty-state {
        max-width: 860px;
        margin: 0 auto;
        text-align: center;
        padding: 5rem 2rem;
        border: 1.5px dashed var(--rule);
        border-radius: 6px;
        background: var(--card-bg);
    }

    .empty-state p {
        font-family: 'Playfair Display', serif;
        font-size: 1.4rem;
        color: var(--muted);
        margin: 0;
    }

    /* ── Staggered reveal ── */
    .post-card {
        opacity: 0;
        transform: translateY(12px);
        animation: slideUp 0.4s ease forwards;
    }

    @@keyframes slideUp {
        to { opacity: 1; transform: translateY(0); }
    }

    .post-card:nth-child(1)  { animation-delay: 0.05s; }
    .post-card:nth-child(2)  { animation-delay: 0.10s; }
    .post-card:nth-child(3)  { animation-delay: 0.15s; }
    .post-card:nth-child(4)  { animation-delay: 0.20s; }
    .post-card:nth-child(5)  { animation-delay: 0.25s; }
    .post-card:nth-child(n+6){ animation-delay: 0.30s; }

    @@media (max-width: 580px) {
        .post-card {
            grid-template-columns: 1fr;
            padding: 1.25rem 1.25rem;
        }
        .post-card-action { display: none; }
        .post-card-title a { background-image: none; }
    }
</style>

<div class="posts-page">
    <div class="posts-header">
        <h1>All Posts</h1>
        <span class="post-count">@Model.Count() @(Model.Count() == 1 ? "entry" : "entries")</span>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <p>No posts yet. Check back soon.</p>
        </div>
    }
    else
    {
        <div class="post-grid">
            @foreach (var post in Model)
            {
                <div class="post-card">
                    <div class="post-card-body">
                        <div class="post-card-meta">By @post.Author</div>
                        <h2 class="post-card-title">
                            <a asp-action="Details" asp-route-id="@post.Id">@post.Title</a>
                        </h2>
                        <p class="post-card-excerpt">@post.Content</p>
                    </div>
                    <div class="post-card-action">
                        <a asp-action="Details" asp-route-id="@post.Id" class="btn-details">
                            Read
                            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                                <path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>

