@model IEnumerable<Post>

@{
    ViewData["Title"] = "Blog Posts";
}

<h1>Blog Posts</h1>

@if (!Model.Any())
{
    <p>No posts found.</p>
}
else
{
    <ul class="list-group">
        @foreach (var post in Model)
        {
            <li class="list-group-item">
                <div>
                    <a asp-controller="Blog" asp-action="Details" asp-route-id="@post.Id">
                        @post.Title
                    </a><br />
                    <small>by @post.Author</small>
                </div>
            </li>
        }
    </ul>
}
