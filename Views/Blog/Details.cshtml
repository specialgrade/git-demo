@model Post

@{
    ViewData["Title"] = "Post Details";
}

<div class="container mt-5">

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">

            <!-- Title -->
            <h1 class="card-title mb-3 fw-bold text-primary">
                @Model.Title
            </h1>

            <!-- Author -->
            <p class="text-muted mb-4">
                Written by <strong>@Model.Author</strong>
            </p>

            <hr />

            <!-- Content -->
            <div class="mt-3">
                <h5 class="fw-semibold mb-2">Content</h5>
                <p class="fs-5 lh-lg">
                    @Model.Content
                </p>
            </div>

            <!-- Back button -->
            <div class="mt-4">
                <a asp-controller="Blog"
                   asp-action="Index"
                   class="btn btn-outline-primary rounded-pill px-4">
                    ← Back to Posts
                </a>
            </div>

        </div>
    </div>

</div>